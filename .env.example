# NEXORA Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an

# ============================================
# DATENBANK (erforderlich)
# ============================================
# Lokale PostgreSQL (Standard für Docker)
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>

# Oder Neon (falls gewünscht):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/nexora?sslmode=require

# ============================================
# SESSION (erforderlich)
# ============================================
# Generiere eine zufällige Zeichenkette für die Session-Verschlüsselung
SESSION_SECRET=<generate-a-random-32-plus-char-secret>

# ============================================
# AUTHENTIFIZIERUNG (optional)
# ============================================
# Clerk Auth (empfohlen fuer lokale + produktive Nutzung)
# Werte aus dem Clerk Dashboard -> API Keys
AUTH_PROVIDER=clerk
VITE_AUTH_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>
# Optional: Kommagetrennte erlaubte Origins (empfohlen)
# CLERK_AUTHORIZED_PARTIES=http://localhost:5000,https://your-domain.com

# Demo-Modus nur explizit aktivieren (sicherer Standard):
# LOCAL_DEMO_AUTH=true

# Replit Auth (nur für Replit Deployment):
# AUTH_PROVIDER=replit
# VITE_AUTH_PROVIDER=replit
# REPLIT_DOMAINS=your-domain.replit.app
# REPL_ID=your-replit-client-id
# ISSUER_URL=https://replit.com/oidc

# ============================================
# KI-APIs (optional)
# ============================================
# OpenRouter API Key (für Dual-AI Feature)
# Hol dir einen kostenlosen Key unter: https://openrouter.ai/keys
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Anthropic API Key (alternativ)
# ANTHROPIC_API_KEY=

# ============================================
# NEON SERVERLESS (optional)
# ============================================
# Set to "true" to use Neon Serverless driver when DATABASE_URL points to Neon
USE_NEON_SERVERLESS=

# ============================================
# DEBUG FLAGS (optional)
# ============================================
# Set to "true" to enable PRD dump diagnostics
DEBUG_PRD_DUMP=

# ============================================
# NODE KONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
